@using System.Text.Json
@{
    ViewData["Title"] = "Access Denied";

    Dictionary<string, JsonElement>? diag = null;
    var diagJson = Context.Request.Query["diag"].FirstOrDefault();
    if (!string.IsNullOrWhiteSpace(diagJson))
    {
        try { diag = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(diagJson); } catch { }
    }

    string Claim(string key) => diag != null && diag.TryGetValue(key, out var v) ? v.ToString() : "";
    string[] ClaimArray(string key)
    {
        if (diag == null || !diag.TryGetValue(key, out var v) || v.ValueKind != JsonValueKind.Array) return [];
        return v.EnumerateArray().Select(e => e.GetString() ?? "").ToArray();
    }
    Dictionary<string, string> ClaimMap(string key)
    {
        if (diag == null || !diag.TryGetValue(key, out var v) || v.ValueKind != JsonValueKind.Object) return new();
        return v.EnumerateObject().ToDictionary(p => p.Name, p => p.Value.ToString());
    }

    var userGroups = ClaimArray("user_groups");
    var requiredGroups = ClaimArray("required_groups");
    var allClaims = ClaimMap("all_claims");
}
<!DOCTYPE html>
<html>
<head>
    <title>Access Denied - SQUAR</title>
    <style>
        body { font-family: sans-serif; max-width: 750px; margin: 40px auto; color: #333; padding: 0 20px; }
        h1 { color: #dc2626; text-align: center; }
        .subtitle { text-align: center; color: #666; margin-bottom: 24px; }
        .section { border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px; margin-bottom: 16px; }
        .section h3 { margin-top: 0; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb; }
        .denied { background: #fef2f2; border-color: #fecaca; }
        .denied h3 { color: #991b1b; border-color: #fecaca; }
        .claims { background: #f0f9ff; border-color: #bae6fd; }
        .claims h3 { color: #0c4a6e; border-color: #bae6fd; }
        .groups { background: #fefce8; border-color: #fde68a; }
        .groups h3 { color: #713f12; border-color: #fde68a; }
        table { width: 100%; border-collapse: collapse; font-size: 0.9em; }
        td, th { text-align: left; padding: 6px 8px; border-bottom: 1px solid #e5e7eb; }
        th { color: #666; width: 180px; font-weight: 600; }
        td { word-break: break-all; }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 0.85em; margin: 2px; }
        .badge-user { background: #dbeafe; color: #1e40af; }
        .badge-required { background: #dcfce7; color: #166534; }
        .badge-missing { background: #fee2e2; color: #991b1b; border: 1px dashed #f87171; }
        .badge-match { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
        .verdict { font-weight: bold; padding: 4px 0; }
        .verdict-denied { color: #dc2626; }
        .verdict-reason { color: #666; font-weight: normal; font-size: 0.9em; }
        .actions { text-align: center; margin-top: 24px; }
        .actions a { color: #1a56db; text-decoration: none; margin: 0 12px; }
        .actions a:hover { text-decoration: underline; }
        .mono { font-family: monospace; font-size: 0.85em; background: #f3f4f6; padding: 1px 4px; border-radius: 3px; }
    </style>
</head>
<body>
    <h1>Access Denied</h1>
    <p class="subtitle">You do not have permission to access SQUAR.</p>

    @if (diag != null)
    {
        <div class="section denied">
            <h3>Authorization Decision</h3>
            <table>
                <tr>
                    <th>Verdict</th>
                    <td>
                        <span class="verdict verdict-denied">DENIED</span>
                        <span class="verdict-reason">
                            &mdash; user's Okta groups do not intersect with the app's required groups
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>User</th>
                    <td><span class="mono">@Claim("user")</span></td>
                </tr>
                <tr>
                    <th>Target App</th>
                    <td><span class="mono">@Claim("app")</span></td>
                </tr>
            </table>
        </div>

        <div class="section groups">
            <h3>Group Claim Comparison</h3>
            <table>
                <tr>
                    <th>User's Groups<br/><small>(from ID token <span class="mono">groups</span> claim)</small></th>
                    <td>
                        @if (userGroups.Length > 0)
                        {
                            @foreach (var g in userGroups)
                            {
                                var matched = requiredGroups.Contains(g, StringComparer.OrdinalIgnoreCase);
                                <span class="badge @(matched ? "badge-match" : "badge-user")">@g</span>
                            }
                        }
                        else
                        {
                            <em>No groups claim found in token</em>
                        }
                    </td>
                </tr>
                <tr>
                    <th>Required Groups<br/><small>(configured in OneAccess)</small></th>
                    <td>
                        @foreach (var g in requiredGroups)
                        {
                            var hasIt = userGroups.Contains(g, StringComparer.OrdinalIgnoreCase);
                            <span class="badge @(hasIt ? "badge-match" : "badge-missing")">@g</span>
                            @if (!hasIt)
                            {
                                <small style="color:#dc2626;">&larr; missing</small>
                            }
                        }
                    </td>
                </tr>
                <tr>
                    <th>Match Result</th>
                    <td>
                        @{
                            var intersection = userGroups.Where(g => requiredGroups.Contains(g, StringComparer.OrdinalIgnoreCase)).ToList();
                        }
                        @if (intersection.Count > 0)
                        {
                            <span>Matched: @string.Join(", ", intersection)</span>
                        }
                        else
                        {
                            <span style="color:#dc2626;">No intersection &mdash; access denied</span>
                        }
                    </td>
                </tr>
            </table>
        </div>

        <div class="section claims">
            <h3>Raw ID Token Claims from Okta</h3>
            <table>
                <tr><th>Issuer (<span class="mono">iss</span>)</th><td>@Claim("issuer")</td></tr>
                <tr><th>Subject (<span class="mono">sub</span>)</th><td>@Claim("sub")</td></tr>
                <tr><th>Audience (<span class="mono">aud</span>)</th><td>@Claim("audience")</td></tr>
                <tr><th>Email (<span class="mono">email</span>)</th><td>@Claim("email")</td></tr>
                <tr><th>Name (<span class="mono">name</span>)</th><td>@Claim("name")</td></tr>
                <tr><th>Issued At (<span class="mono">iat</span>)</th><td>@Claim("issued_at")</td></tr>
                <tr><th>Expires (<span class="mono">exp</span>)</th><td>@Claim("expiry")</td></tr>
            </table>

            <details style="margin-top: 12px;">
                <summary style="cursor:pointer; color:#0c4a6e; font-weight:600;">All Claims (raw)</summary>
                <table style="margin-top: 8px;">
                    @foreach (var kv in allClaims)
                    {
                        <tr>
                            <th><span class="mono">@kv.Key</span></th>
                            <td>@kv.Value</td>
                        </tr>
                    }
                </table>
            </details>
        </div>
    }
    else
    {
        <p style="text-align:center;">No diagnostic data available. Contact your administrator.</p>
    }

    <div class="actions">
        <a href="/auth/logout">Try a different account</a>
    </div>
</body>
</html>
